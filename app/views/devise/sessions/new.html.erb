<div class="flex items-center justify-center min-h-[calc(100vh-90px)] px-4">
  <div class="[background:var(--um-sand)] rounded-2xl p-6 w-full max-w-md shadow-lg relative">

    <h2 class="text-xl font-semibold mb-4 text-slate-800">Login</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { "data-turbo" => "false" }) do |f| %>
      <div class="mb-4">
        <label class="block text-sm text-slate-600 mb-1">Email</label>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border rounded-lg px-3 py-2" %>
      </div>

      <div class="mb-6">
        <label class="block text-sm text-slate-600 mb-1">Password</label>
        <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full border rounded-lg px-3 py-2" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-4 flex items-center gap-2 text-sm text-slate-600">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me %>
        </div>
      <% end %>

      <%= f.submit "Sign In",
            class: "um-btn-secondary w-full py-2 rounded-full font-semibold cursor-pointer" %>
    <% end %>

    <div class="mt-4 text-center text-base text-slate-500">
      <%= link_to "Forgot your password?", new_user_password_path,
            class: "font-semibold hover:underline", style: "color: var(--um-primary);" %>
    </div>

    <div class="mt-2 text-center text-base text-slate-500">
      Don't have an account?
      <%= link_to "Create new account", new_user_registration_path,
            class: "font-bold hover:underline", style: "color: var(--um-forest);" %>
    </div>

  </div>
</div>
