<!DOCTYPE html>
<html>
  <head>
    <title>UrbanMeet</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="text-gray-900" style="background: var(--um-sand);">
    <%= render "shared/navbar" %>

    <main>
      <% if notice.present? %>
        <div id="flash-notice" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-full text-sm font-semibold shadow-md transition-opacity duration-500"
             style="background: rgba(210,224,191,.95); color: var(--um-forest);">
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div id="flash-alert" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-full text-sm font-semibold shadow-md transition-opacity duration-500"
             style="background: rgba(255,220,220,.95); color: #c0392b;">
          <%= alert %>
        </div>
      <% end %>
      <script>
        document.addEventListener("turbo:load", function() {
          ["flash-notice", "flash-alert"].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) {
              setTimeout(function() {
                el.style.opacity = "0";
                setTimeout(function() { el.remove(); }, 500);
              }, 3000);
            }
          });
        });
      </script>
      <%= yield %>
    </main>
  </body>
</html>
