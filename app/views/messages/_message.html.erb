<div class="flex gap-3 mb-4" id="message_<%= message.id %>">
  <div class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-xs font-semibold text-gray-600 shrink-0">
    <%= message.user.name.split.map(&:first).first(2).join.upcase %>
  </div>
  <div>
    <div class="flex items-baseline gap-2">
      <p class="text-xs font-semibold text-gray-800"><%= message.user.name %></p>
      <p class="text-xs text-gray-400"><%= message.created_at.strftime("%H:%M") %></p>
    </div>
    <p class="text-sm text-gray-600 mt-0.5 leading-relaxed"><%= message.body %></p>
  </div>
</div>
