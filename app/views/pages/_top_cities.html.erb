<section class="py-16" style="background: var(--um-sand);">
  <div class="w-full px-8 md:px-20 lg:px-32">

    <div class="flex items-end justify-between">
      <div class="w-full">

        <p class="text-sm font-semibold tracking-wide text-gray-500 uppercase">
          Explore
        </p>

        <h2 class="mt-2 text-3xl font-semibold tracking-tight text-gray-900">
          Trending Cities
        </h2>

        <p class="mt-3 text-gray-600 max-w-xl">
          Start where people are meeting right now.
        </p>
      </div>
    </div>

    <% country_codes = {
      "Rome" => "it",
      "Berlin" => "de",
      "Paris" => "fr",
      "Madrid" => "es",
      "London" => "gb",
      "Vienna" => "at"
    } %>

    <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-10">
      <% @cities.each do |city| %>

        <%= link_to events_path(city_id: city.id), class: "flex flex-col items-start w-40 group" do %>

          <!-- Circle + Flag Badge -->
          <div class="relative w-40 h-40">
            <div class="w-40 h-40 rounded-full overflow-hidden shadow-md ring-1 ring-black/5">
              <%= image_tag "#{city.name.downcase}.jpg",
                    alt: city.name,
                    class: "w-full h-full object-cover group-hover:scale-105 transition duration-300",
                    loading: "lazy" %>
            </div>

            <!-- Flag -->
            <div class="absolute -bottom-0 -right-0 w-9 h-9 rounded-full bg-zinc-900 shadow-lg flex items-center justify-center ring-2 ring-white">
              <img src="https://flagcdn.com/w40/<%= country_codes[city.name] %>.png"
                alt="<%= country_codes[city.name].upcase %>"
                class="w-7 h-7 rounded-full"
                loading="lazy">
            </div>
          </div>

          <p class="mt-5 w-full text-center text-xl font-semibold tracking-tight group-hover:underline">
            <%= city.name %>
          </p>

        <% end %>

      <% end %>
    </div>

  </div>
</section>
